# Zaka-Stream Backend Environment Variables
# Copy to .env and fill in values after deploying the contract

# ── Stellar / Soroban ─────────────────────────────────────
STELLAR_NETWORK=testnet
# Paste the Contract ID output from packages/contracts/deploy.sh
CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Stellar Testnet RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Server ────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0

# ── Indexer ───────────────────────────────────────────────
# How often the indexer polls for new events (milliseconds)
POLL_INTERVAL_MS=5000

# ── Storage ───────────────────────────────────────────────
# Relative path from project root to the streams JSON file
STREAMS_DB_PATH=data/streams.json
