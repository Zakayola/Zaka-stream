# Zaka-Stream Frontend Environment Variables
# Copy to .env.local and fill in values after deploying the contract

# ── Soroban Contract ──────────────────────────────────────
# Paste the Contract ID output from packages/contracts/deploy.sh
NEXT_PUBLIC_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Backend API ───────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ── Stellar Network ───────────────────────────────────────
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK=testnet
